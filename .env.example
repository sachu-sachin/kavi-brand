# Copy to .env and fill in real values. Never commit the real .env.

# MySQL connection string used by Prisma (CLI) and the MariaDB driver adapter (runtime).
DATABASE_URL="mysql://user:password@localhost:3306/kavi_db"

# --- Admin auth ---
ADMIN_EMAIL="admin@kavi.com"
# bcrypt hash of the admin password. Generate with: npm run hash-password "your-password"
# Escape each `$` as `\$` so Next.js does not interpret it as variable expansion.
ADMIN_PASSWORD_HASH=""

# Secret used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# --- Razorpay ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# --- Hostinger SMTP (Nodemailer) ---
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Kavi Foods <orders@yourdomain.com>"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
